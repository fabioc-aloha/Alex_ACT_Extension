{
    "name": "alex-act-edition",
    "displayName": "Alex ACT Edition",
    "description": "Artificial Critical Thinking for GitHub Copilot. 33 instructions, 17 skills, 20 prompts, 3 agents, and 20 muscles that teach your AI to reason honestly.",
    "version": "1.0.0",
    "publisher": "fabioc-aloha",
    "license": "MIT",
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Machine Learning",
        "Other"
    ],
    "keywords": [
        "copilot",
        "ai",
        "critical-thinking",
        "cognitive-architecture",
        "instructions",
        "skills",
        "prompts",
        "agents"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "alex-act.bootstrap",
                "title": "Bootstrap This Workspace",
                "category": "ACT"
            },
            {
                "command": "alex-act.upgrade",
                "title": "Upgrade Brain",
                "category": "ACT"
            },
            {
                "command": "alex-act.status",
                "title": "Show Status",
                "category": "ACT"
            },
            {
                "command": "alex-act.mall-search",
                "title": "Search Plugin Mall",
                "category": "ACT"
            },
            {
                "command": "alex-act.convert.md-to-word",
                "title": "Convert to Word (.docx)",
                "category": "ACT Convert"
            },
            {
                "command": "alex-act.convert.md-to-html",
                "title": "Convert to HTML",
                "category": "ACT Convert"
            },
            {
                "command": "alex-act.convert.md-to-eml",
                "title": "Convert to Email (.eml)",
                "category": "ACT Convert"
            },
            {
                "command": "alex-act.convert.md-to-txt",
                "title": "Convert to Plain Text",
                "category": "ACT Convert"
            },
            {
                "command": "alex-act.convert.docx-to-md",
                "title": "Convert to Markdown",
                "category": "ACT Convert"
            },
            {
                "command": "alex-act.convert.html-to-md",
                "title": "Convert to Markdown",
                "category": "ACT Convert"
            }
        ],
        "submenus": [
            {
                "id": "alex-act.convert",
                "label": "ACT Convert"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "submenu": "alex-act.convert",
                    "when": "resourceExtname =~ /\\.(md|docx|html|htm)$/",
                    "group": "7_modification"
                }
            ],
            "alex-act.convert": [
                {
                    "command": "alex-act.convert.md-to-word",
                    "when": "resourceExtname == .md",
                    "group": "1_from_md@1"
                },
                {
                    "command": "alex-act.convert.md-to-html",
                    "when": "resourceExtname == .md",
                    "group": "1_from_md@2"
                },
                {
                    "command": "alex-act.convert.md-to-eml",
                    "when": "resourceExtname == .md",
                    "group": "1_from_md@3"
                },
                {
                    "command": "alex-act.convert.md-to-txt",
                    "when": "resourceExtname == .md",
                    "group": "1_from_md@4"
                },
                {
                    "command": "alex-act.convert.docx-to-md",
                    "when": "resourceExtname == .docx",
                    "group": "2_to_md@1"
                },
                {
                    "command": "alex-act.convert.html-to-md",
                    "when": "resourceExtname =~ /\\.(html|htm)$/",
                    "group": "2_to_md@2"
                }
            ]
        }
    },
    "icon": "assets/icon.png",
    "galleryBanner": {
        "color": "#1e293b",
        "theme": "dark"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/fabioc-aloha/Alex_ACT_Edition"
    },
    "homepage": "https://github.com/fabioc-aloha/Alex_ACT_Edition#readme"
}
